<body>

    <div class="app-container">
        <header>
            <div class="logo-stripes">
                <div class="stripe"></div>
                <div class="stripe"></div>
                <div class="stripe"></div>
            </div>
            <h1>Patrick&apos;s Schedule</h1>
            <p>Week of March 24, 2026</p>
        </header>

        <main>
            <h2>Upcoming Shifts</h2>
            <div class="shift-list" id="my-shifts-container">
            </div>

            <div class="btn-container">
                <button class="btn btn-swap-main" onclick="openModal(&quot;swap-modal&quot;)">Shift Swap</button>
                <button class="btn btn-open-main" onclick="openModal(&quot;claim-modal&quot;)">Open Shifts</button>
            </div>
        </main>

        <footer>
            <div class="total-hours-label">Total Hours:</div>
            <div class="total-hours-value" id="total-hours-display">0</div>
        </footer>

        <div class="modal-overlay" id="swap-modal">
            <div class="modal-content">
                <div class="modal-header">
                    <h2>Select Shift to Swap</h2>
                    <button class="close-btn" onclick="closeModal(&quot;swap-modal&quot;)">&times;</button>
                </div>
                <div class="modal-body shift-list" id="swap-list-container">
                </div>
            </div>
        </div>

        <div class="modal-overlay" id="claim-modal">
            <div class="modal-content">
                <div class="modal-header">
                    <h2>Available Open Shifts</h2>
                    <button class="close-btn" onclick="closeModal(&quot;claim-modal&quot;)">&times;</button>
                </div>
                <div class="modal-body shift-list" id="claim-list-container">
                </div>
            </div>
        </div>

        <div id="toast" class="toast">Action Successful!</div>
    </div>

    <script>
        let myShifts = [
            { id: 1, sortOrder: 1, day: "Tuesday, 24th March", time: "09:00 AM - 04:00 PM", role: "Front Counter", hours: 7 },
            { id: 2, sortOrder: 3, day: "Thursday, 26th March", time: "11:00 AM - 07:00 PM", role: "Drive-Thru Window", hours: 8 },
            { id: 3, sortOrder: 5, day: "Saturday, 28th March", time: "04:00 PM - 11:00 PM", role: "Fry Cook", hours: 7 },
            { id: 4, sortOrder: 6, day: "Sunday, 29th March", time: "12:00 PM - 08:00 PM", role: "Expeditor / Packer", hours: 8 }
        ];

        let openShifts = [
            { id: 101, sortOrder: 2, day: "Wednesday, 25th March", time: "10:00 AM - 03:00 PM", role: "Front Counter", hours: 5 },
            { id: 102, sortOrder: 4, day: "Friday, 27th March", time: "05:00 PM - 11:00 PM", role: "Kitchen Prep", hours: 6 },
            { id: 103, sortOrder: 7, day: "Monday, 30th March", time: "08:00 AM - 02:00 PM", role: "Drive-Thru Headset", hours: 6 }
        ];

        function updateApp() {
            renderMyShifts();
            calculateTotalHours();
        }

        function renderMyShifts() {
            const container = document.getElementById("my-shifts-container");
            container.innerHTML = "";
            
            myShifts.sort((a, b) => a.sortOrder - b.sortOrder);

            if(myShifts.length === 0) {
                container.innerHTML = `<p style="color: #666; font-style: italic;">You have no shifts scheduled this week.</p>`;
                return;
            }

            myShifts.forEach(shift => {
                container.innerHTML += `
                    <div class="shift-card">
                        <div class="shift-info">
                            <h3>` + shift.day + `</h3>
                            <p>` + shift.time + `</p>
                            <span class="shift-role">` + shift.role + `</span>
                        </div>
                        <div style="font-weight: bold; color: var(--text-gray); font-size: 0.9rem;">
                            ` + shift.hours + ` hrs
                        </div>
                    </div>
                `;
            });
        }

        function calculateTotalHours() {
            const total = myShifts.reduce((sum, shift) => sum + shift.hours, 0);
            document.getElementById("total-hours-display").innerText = total + " hrs";
        }

        function openModal(modalId) {
            if (modalId === "swap-modal") renderSwapModal();
            if (modalId === "claim-modal") renderClaimModal();
            document.getElementById(modalId).classList.add("active");
        }

        function closeModal(modalId) {
            document.getElementById(modalId).classList.remove("active");
        }

        function renderSwapModal() {
            const container = document.getElementById("swap-list-container");
            container.innerHTML = "";

            if(myShifts.length === 0) {
                container.innerHTML = `<p>No shifts available to swap.</p>`;
                return;
            }

            myShifts.forEach(shift => {
                container.innerHTML += `
                    <div class="shift-card">
                        <div class="shift-info">
                            <h3>` + shift.day + `</h3>
                            <p>` + shift.time + `</p>
                        </div>
                        <button class="btn-small btn-small-swap" onclick="processSwap(` + shift.id + `)">Swap This</button>
                    </div>
                `;
            });
        }

        function renderClaimModal() {
            const container = document.getElementById("claim-list-container");
            container.innerHTML = "";

            if(openShifts.length === 0) {
                container.innerHTML = `<p>No open shifts available to claim.</p>`;
                return;
            }

            openShifts.forEach(shift => {
                container.innerHTML += `
                    <div class="shift-card">
                        <div class="shift-info">
                            <h3>` + shift.day + `</h3>
                            <p>` + shift.time + `</p>
                            <p style="font-size: 0.8rem; color: #666; margin-top:2px;">` + shift.role + ` (` + shift.hours + ` hrs)</p>
                        </div>
                        <button class="btn-small btn-small-claim" onclick="processClaim(` + shift.id + `)">Claim</button>
                    </div>
                `;
            });
        }

        function processSwap(shiftId) {
            myShifts = myShifts.filter(s => s.id !== shiftId);
            closeModal("swap-modal");
            updateApp();
            showToast("Shift swap request submitted!");
        }

        function processClaim(shiftId) {
            const shiftIndex = openShifts.findIndex(s => s.id === shiftId);
            
            if(shiftIndex > -1) {
                const shift = openShifts[shiftIndex];
                openShifts.splice(shiftIndex, 1);
                myShifts.push(shift);
                closeModal("claim-modal");
                updateApp();
                showToast("Claimed! Added " + shift.hours + " hours to your schedule.");
            }
        }

        function showToast(message) {
            const toast = document.getElementById("toast");
            toast.innerText = message;
            toast.classList.add("show");
            setTimeout(() => {
                toast.classList.remove("show");
            }, 3000);
        }

        updateApp();
    </script>
</body>
</html>
